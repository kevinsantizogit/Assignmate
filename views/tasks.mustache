{{> partials/header}}

<div class="row space">
  <h1>Tasks</h1>
  <a class="linkbtn" href="/tasks/new">+ New Task</a>
</div>

{{#tasks}}
  <div class="card taskrow">
    <div>
      <div class="titleline">
        <a href="/tasks/{{id}}"><strong>{{title}}</strong></a>
      </div>
      <div class="subline">{{course}} • {{task_type}} • due {{due_date}}</div>
    </div>
    <div class="row">
      <form method="POST" action="/tasks/{{id}}/toggle">
        <button type="submit">
          {{#completed}}Mark Incomplete{{/completed}}
          {{^completed}}Mark Complete{{/completed}}
        </button>
      </form>
      <a class="linkbtn" href="/tasks/{{id}}/edit">Edit</a>
      <form method="POST" action="/tasks/{{id}}/delete">
        <button type="submit" class="danger">Delete</button>
      </form>
    </div>
  </div>
{{/tasks}}

{{^tasks}}
  <p>No tasks yet. Click "New Task".</p>
{{/tasks}}

{{> partials/footer}}